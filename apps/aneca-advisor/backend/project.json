{
  "name": "aneca-advisor-backend",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/aneca-advisor/backend",
  "targets": {
    "setup": {
      "command": "python3 -m venv .venv && .venv/bin/python3 -m pip install -r requirements.txt",
      "options": {
        "cwd": "apps/aneca-advisor/backend"
      }
    },
    "run": {
      "command": ".venv/bin/python3 app.py",
      "options": {
        "cwd": "apps/aneca-advisor/backend"
      }
    },
    "test": {
      "command": ".venv/bin/python3 -m pytest tests/",
      "options": {
        "cwd": "apps/aneca-advisor/backend"
      }
    },
    "migration": {
      "command": ".venv/bin/alembic revision --message",
      "options": {
        "cwd": "apps/aneca-advisor/backend"
      }
    },
    "migrate": {
      "command": ".venv/bin/alembic upgrade head",
      "options": {
        "cwd": "apps/aneca-advisor/backend"
      }
    }
  }
}
