# Your public domain (no https://, no trailing slash)
DOMAIN=apps.example.com

# GitHub repo in owner/repo format — used to pull images from GHCR
# e.g. valentinlineiro/apps-platform
GHCR_REPO=

# Portal
PORTAL_SESSION_SECRET=     # openssl rand -hex 32

# Keycloak OAuth client (must match the client configured in Keycloak)
OAUTH_CLIENT_ID=portal
OAUTH_CLIENT_SECRET=       # copy from Keycloak → Clients → portal → Credentials

# Keycloak admin credentials
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=   # choose a strong password

# Postgres
POSTGRES_USER=keycloak
POSTGRES_PASSWORD=         # choose a strong password

# Gemini
GEMINI_API_KEY=
