{$DOMAIN} {
    @keycloak {
        path /keycloak/* /realms/* /resources/* /admin/* /js/* /welcome/*
    }
    handle @keycloak {
        reverse_proxy keycloak:8080
    }

    # Everything else → portal nginx (which proxies /api/, /auth/, /exam-corrector/ internally)
    handle {
        reverse_proxy portal:80
    }
}
